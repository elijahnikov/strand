{
  "name": "@omi/backend",
  "private": true,
  "type": "module",
  "exports": {
    "./*": "./convex/*",
    "./env": "./env.ts",
    "./api": {
      "types": "./convex/_generated/api.d.ts",
      "default": "./convex/_generated/api.js"
    },
    "./utils": "./convex/utils.ts",
    "./instant": "./instant/index.ts",
    "./instant/schema": "./instant/instant.schema.ts"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "bunx convex dev",
    "generate": "cd convex/betterAuth bunx @better-auth/cli generate -y",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@omi/tsconfig": "workspace:*",
    "convex-test": "^0.0.49",
    "typescript": "catalog:",
    "vitest": "^3"
  },
  "dependencies": {
    "@better-auth/stripe": "catalog:better-auth",
    "@convex-dev/better-auth": "catalog:convex",
    "@convex-dev/presence": "catalog:convex",
    "@convex-dev/rate-limiter": "catalog:convex",
    "@convex-dev/resend": "catalog:convex",
    "@instantdb/core": "catalog:instant",
    "@instantdb/react": "catalog:instant",
    "@omi/ai": "workspace:*",
    "@omi/email": "workspace:*",
    "convex": "catalog:convex",
    "convex-helpers": "catalog:convex",
    "fflate": "^0.8.2",
    "marked": "^14.1.3",
    "stripe": "^22.0.2"
  }
}
