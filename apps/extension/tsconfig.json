{
  "extends": "@strand/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2022", "dom", "dom.iterable"],
    "jsx": "preserve",
    "types": ["chrome"],
    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./src/*"]
    },
    "strictNullChecks": true,
    "checkJs": false
  },
  "include": [
    ".wxt/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "env.d.ts",
    "wxt.config.ts"
  ],
  "exclude": ["node_modules", ".output"]
}
