{
  "name": "create-t3-turbo",
  "private": true,
  "engines": {
    "node": "^25.7.0"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "auth:generate": "bun -F @omi/backend generate",
    "dev": "turbo watch dev --continue",
    "typecheck": "turbo run typecheck --filter=!@omi/expo",
    "test": "turbo run test",
    "ui-add": "turbo run ui-add",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@turbo/gen": "^2.5.8",
    "dotenv-cli": "^10.0.0",
    "turbo": "^2.5.8",
    "typescript": "catalog:",
    "ultracite": "7.3.2"
  },
  "packageManager": "bun@1.2.14",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tooling/*"
    ],
    "catalog": {
      "react-hook-form": "^7.71.1",
      "typescript": "^5.9.3",
      "zod": "^4.3.5",
      "@types/node": "^25.0.3",
      "@remixicon/react": "^4.8.0"
    },
    "catalogs": {
      "tailwind": {
        "tailwindcss": "^4.1.18",
        "@tailwindcss/vite": "^4.1.18",
        "@tailwindcss/postcss": "^4.1.18",
        "postcss": "^8.5.6"
      },
      "better-auth": {
        "better-auth": "^1.5.3",
        "@better-auth/expo": "^1.5.0",
        "@better-auth/cli": "^1.4.21",
        "@better-auth/infra": "^0.1.8"
      },
      "convex": {
        "convex": "^1.34.1",
        "@convex-dev/react-query": "^0.1.0",
        "@convex-dev/better-auth": "^0.11.3",
        "@convex-dev/resend": "^0.2.3",
        "convex-helpers": "^0.1.114",
        "@convex-dev/presence": "^0.3.0"
      },
      "instant": {
        "@instantdb/core": "^1.0.1",
        "@instantdb/react": "^1.0.1"
      },
      "tanstack": {
        "@tanstack/react-query": "^5.90.16",
        "@tanstack/react-form": "^1.27.7",
        "@tanstack/react-router": "^1.146.0",
        "@tanstack/react-router-devtools": "^1.146.0",
        "@tanstack/react-router-ssr-query": "^1.146.0",
        "@tanstack/react-router-with-query": "^1.130.17",
        "@tanstack/react-start": "^1.146.0",
        "@tanstack/react-hotkeys": "^0.9.0"
      },
      "vite": {
        "vite": "^7.3.1",
        "@vitejs/plugin-react": "^5.1.2",
        "vite-tsconfig-paths": "^5.1.4"
      },
      "react": {
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "react": "^19.2.3",
        "react-dom": "^19.2.3"
      },
      "email": {
        "react-email": "^6.0.0",
        "@react-email/components": "^1.0.12",
        "@react-email/render": "^2.0.7"
      }
    }
  }
}
